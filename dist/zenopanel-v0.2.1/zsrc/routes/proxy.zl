# 17. Reverse Proxy API
http.get: '/api/proxy/list' {
    auth.guard
    proxy.list: { as: $proxies }
    http.ok: { data: $proxies }
}

http.post: '/api/proxy/add' {
    auth.guard
    http.json_body: { as: $body }
    coalesce: $body.domain {
        default: ''
        as: $clean_domain
    }
    coalesce: $body.alternative_domain {
        default: ''
        as: $clean_alternative_domain
    }
    coalesce: $body.path {
        default: '/'
        as: $clean_path
    }
    coalesce: $body.strip_path {
        default: false
        as: $clean_strip_path
    }
    coalesce: $body.enabled {
        default: true
        as: $clean_enabled
    }
    coalesce: $body.ssl_enabled {
        default: false
        as: $clean_ssl_enabled
    }
    coalesce: $body.managed_process_id {
        default: ''
        as: $clean_process_id
    }
    coalesce: $body.rule_type {
        default: 'proxy'
        as: $clean_rule_type
    }

    proxy.add: $body.name {
        domain: $clean_domain
        alternative_domain: $clean_alternative_domain
        path: $clean_path
        target: $body.target
        strip_path: $clean_strip_path
        enabled: $clean_enabled
        ssl_enabled: $clean_ssl_enabled
        managed_process_id: $clean_process_id
        rule_type: $clean_rule_type
        as: $id
    }
    http.ok: {
        id: $id
        message: "Proxy rule berhasil ditambahkan"
    }
}

http.post: '/api/proxy/update' {
    auth.guard
    http.json_body: { as: $body }
    coalesce: $body.domain {
        default: ''
        as: $clean_domain
    }
    coalesce: $body.alternative_domain {
        default: ''
        as: $clean_alternative_domain
    }
    coalesce: $body.path {
        default: '/'
        as: $clean_path
    }
    coalesce: $body.strip_path {
        default: false
        as: $clean_strip_path
    }
    coalesce: $body.enabled {
        default: true
        as: $clean_enabled
    }
    coalesce: $body.ssl_enabled {
        default: false
        as: $clean_ssl_enabled
    }
    coalesce: $body.managed_process_id {
        default: ''
        as: $clean_process_id
    }
    coalesce: $body.rule_type {
        default: 'proxy'
        as: $clean_rule_type
    }

    proxy.update: $body.id {
        name: $body.name
        domain: $clean_domain
        alternative_domain: $clean_alternative_domain
        path: $clean_path
        target: $body.target
        strip_path: $clean_strip_path
        enabled: $clean_enabled
        ssl_enabled: $clean_ssl_enabled
        managed_process_id: $clean_process_id
        rule_type: $clean_rule_type
        as: $success
    }
    if: $success {
        then: {
            http.ok: { message: "Proxy rule berhasil diperbarui" }
        }
        else: {
            http.bad_request: { message: $error }
        }
    }
}

http.post: '/api/proxy/delete' {
    auth.guard
    http.json_body: { as: $body }
    proxy.delete: $body.id { as: $success }
    if: $success {
        then: {
            http.ok: { message: "Proxy rule berhasil dihapus" }
        }
        else: {
            http.bad_request: { message: $error }
        }
    }
}

http.post: '/api/proxy/toggle' {
    auth.guard
    http.json_body: { as: $body }
    proxy.toggle: $body.id {
        enabled: $body.enabled
        as: $success
    }
    if: $success {
        then: {
            http.ok: { message: "Status proxy rule berhasil diubah" }
        }
        else: {
            http.bad_request: { message: $error }
        }
    }
}
