# ==========================================
# 1. SERVER
# ==========================================
APP_PORT=:3001
APP_TLS_PORT=:8443
APP_ENV=development
# The user that the systemd service runs as. If set to a non-root user,
# ZenoPanel will be configured with CAP_NET_BIND_SERVICE capabilities.
# APP_USER=root


# ==========================================
# 2. DATABASE
# ==========================================
DB_DRIVER=sqlite
DB_NAME=./zeno.db


# ==========================================
# 3. SECURITY
# ==========================================
JWT_SECRET=
# CSRF
CSRF_ENABLED=true
CSRF_EXCEPT=/api,/health

# ACME SSL
SSL_CONTACT_EMAIL=admin@zenopanel.com


# ==========================================
# 4. WAF & RATE LIMITING
# ==========================================
WAF_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60


# ==========================================
# 5. CLOUDFLARE DNS API (For Wildcard / DNS-01 SSL)
# ==========================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
