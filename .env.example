# ==========================================
# 1. SERVER
# ==========================================
APP_PORT=:3000
APP_TLS_PORT=:8443

# Application mode
# development = tampilkan detail error di browser
# production  = sembunyikan error detail
APP_ENV=development

# Custom entrance/login path (default: /login)
# Ubah ini untuk security-by-obscurity
# ENTRANCE_PATH=/login


# ==========================================
# 2. DATABASE
# ==========================================
# Saat ini hanya SQLite yang didukung
DB_DRIVER=sqlite
DB_NAME=./zeno.db

# Database internal untuk ZenoPanel (opsional, bisa digabung dengan DB_NAME)
# DB_INTERNAL_NAME=./zeno_internal.db


# ==========================================
# 3. SECURITY
# ==========================================
# JWT secret untuk signing token — wajib diisi di production
# Generate: openssl rand -base64 32
JWT_SECRET=

# Kredensial admin awal — hanya dipakai SEKALI saat tabel users masih kosong.
# Setelah user pertama tersimpan di DB, variabel ini diabaikan sepenuhnya.
# Hapus atau komentari setelah setup pertama selesai.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# CSRF protection
CSRF_ENABLED=true
# Path prefix yang dikecualikan dari CSRF check (comma-separated)
CSRF_EXCEPT=/api,/health
