# ==========================================
# 1. SERVER
# ==========================================
APP_PORT=:80
APP_TLS_PORT=:443
MGMT_PORT=:3002
APP_ENV=development

# Custom entrance path for admin login page (useful for hiding login panel from scanners/attacks)
ENTRANCE_PATH=/login

# Default credentials seeded on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ==========================================
# 2. DATABASE
# ==========================================
DB_NAME=./zeno.db
# DB_INTERNAL_NAME=./zeno_internal.db

# ==========================================
# 3. SECURITY & SSL
# ==========================================
# Keep JWT secret persistent to prevent sessions from invalidating on restart
JWT_SECRET=

# APIs or paths exempted from CSRF checks (comma-separated)
CSRF_EXCEPT=/api,/health

# Email address for Let's Encrypt SSL certificates (required for SSL renewal notification)
SSL_CONTACT_EMAIL=admin@yourmail.com
# Set to true to use Let's Encrypt Production API, or false for Staging/Test environment
SSL_PRODUCTION=false

# ==========================================
# 4. CLOUDFLARE DNS API (Required for Wildcard / DNS-01 SSL Certificates)
# ==========================================
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ==========================================
# 5. ZENO CONTAINER (OCI-Compliant Container Runtime Manager)
# ==========================================
# Data directory for container states, bundle dirs, and volumes (defaults to /var/lib/zeno-container)
# ZENO_CONTAINER_DATA_DIR=
