# ==========================================
# 1. SERVER CONFIGURATION
# ==========================================
# Application port
APP_PORT=:3000

# Application Mode
# development = Show detailed errors in browser (Best for coding)
# production  = Hide errors, show generic messages (Best for live)
APP_ENV=development
# Live Reload Configuration (in development)
LIVERELOAD_ENABLED=false

# Rate Limiting
# Maximum number of requests per time window
RATE_LIMIT_REQUESTS=5000
# Time window in seconds (60 = 1 minute)
RATE_LIMIT_WINDOW=60

# Request Timeout (Context-Aware Executor)
# Maximum execution time for HTTP requests to prevent infinite loops
# Format: duration string (e.g., "30s", "1m", "2m30s")
ZENO_REQUEST_TIMEOUT=30s


# ==========================================
# 2. DATABASE (MySQL / SQLite / Postgres)
# ==========================================
# Driver Options: mysql, sqlite, postgres, sqlserver
DB_DRIVER=sqlite

# Format: IP:PORT
# DB_HOST=127.0.0.1:3306
# DB_USER=root
# DB_PASS=
DB_NAME=./zeno.db
# Database Connection Pool Configuration
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ==========================================
# 3. SECURITY (JWT & CSRF)
# ==========================================
# Secret key for token signing. 
# Run 'zeno key:generate' to set this automatically in your local .env
JWT_SECRET=
CSRF_TOKEN=your_csrf_token_here_must_be_32_bytes
# CSRF Configuration
CSRF_ENABLED=true
CSRF_SECURE=false
CSRF_SAMESITE=lax
CSRF_EXCEPT=/api,/health

# Trusted Origins for CSRF (comma separated)
TRUSTED_ORIGINS=

# ==========================================
# 4. EMAIL SERVICE (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password


# ==========================================
# 6. REDIS (Distributed Cache)
# ==========================================
REDIS_HOST=localhost:6379
REDIS_PASS=
REDIS_DB=0

# ==========================================
# 7. WORKER & SECURITY
# ==========================================
WORKER_ENABLED=false

# Content Security Policy (CSP)
# Set to 'true' or 'enable' to activate security headers. Disabled by default.
CSP_ENABLED=false
# CSP Allowed Domains (space separated)
CSP_ALLOWED_DOMAINS="https://code.jquery.com https://unpkg.com"


